    "Schedule": {
      "CronExpression": "* * * * *",
      "TimeZone": "UTC",
      "Enabled": true
    }
  },

  "DownloadEmployeeOptions": {
    "LookbackDays": 5,
    "DownloadToArchive": false,
    "Schedule": {
      "CronExpression": "* * * * *",
      "TimeZone": "UTC",
      "Enabled": true
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
