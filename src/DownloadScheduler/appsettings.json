{
  "InternalApi": {
    "BaseUrl": "https://localhost:7001"
  },

  "DownloadErrorReportsOptions": {
    "LookbackDays": 30,
    "DownloadToArchive": true,
    "Schedule": {
      "CronExpression": "0 6 * * *",
      "TimeZone": "UTC",
      "Enabled": true
    }
  },

  "DownloadAlertsOptions": {
    "LookbackDays": 7,
    "DownloadToArchive": false,
    "Schedule": {
      "CronExpression": "0 8 * * *",
      "TimeZone": "UTC",
      "Enabled": true
    }
  },

  "DownloadEmployeeOptions": {
    "LookbackDays": 90,
    "DownloadToArchive": true,
    "Schedule": {
      "CronExpression": "0 0 * * 1",
      "TimeZone": "UTC",
      "Enabled": false
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
